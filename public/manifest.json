{
  "manifest_version": 3,
  "name": "Sheriff's Command Center",
  "version": "1.0",
  "description": "High-performance browser start page.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "bookmarks", "topSites"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
